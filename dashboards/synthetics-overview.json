    {
      "id": 9,
      "type": "table",
      "title": "All Probes",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Success",
            "desc": false
          }
        ],
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Success"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": 1
                    }
                  ]
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "FAILING"
                      },
                      "1": {
                        "text": "OK"
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Last Run"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dateTimeFromNow"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Duration (ms)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              },
              {
                "id": "decimals",
                "value": 0
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "name": "Probe",
              "namespace": "Namespace",
              "kind": "Kind",
              "Value #success": "Success",
              "Value #last_run": "Last Run",
              "Value #duration": "Duration (ms)"
            },
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "otel_scope_name": true
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "synthetics_probe_up{namespace=~\"$namespace\"}",
          "legendFormat": "",
          "instant": true,
          "refId": "success",
          "format": "table"
        },
        {
          "expr": "synthetics_last_run_timestamp{namespace=~\"$namespace\"} * 1000",
          "legendFormat": "",
          "instant": true,
          "refId": "last_run",
          "format": "table"
        },
        {
          "expr": "synthetics_probe_duration_ms{namespace=~\"$namespace\"}",
          "legendFormat": "",
          "instant": true,
          "refId": "duration",
          "format": "table"
        }
      ]
