        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "count(synthetics_probe_up{namespace=~\"$namespace\"})",
