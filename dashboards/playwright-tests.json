{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "title": "Overview",
      "url": "/d/synthetics-overview",
      "type": "link",
      "icon": "arrow-left",
      "targetBlank": false
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["synthetics", "playwright", "tests"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Namespace",
        "multi": false,
        "name": "namespace",
        "options": [],
        "query": {
          "query": "label_values(synthetics_test{kind=\"PlaywrightTest\"}, namespace)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"}
      },
      {
        "current": {},
        "hide": 0,
        "includeAll": true,
        "label": "Test",
        "multi": true,
        "name": "test",
        "options": [],
        "query": "label_values(synthetics_test{kind=\"PlaywrightTest\", namespace=\"$namespace\"}, name)",
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"}
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Synthetics / PlaywrightTests",
  "uid": "synthetics-playwright-tests",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Tests passing",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{
        "expr": "count(synthetics_test{kind=\"PlaywrightTest\", namespace=\"$namespace\", name=~\"$test\", result=\"ok\"})",
        "refId": "A"
      }],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null}
          ]},
          "color": {"mode": "thresholds"}
        }
      }
    },
    {
      "id": 2,
      "title": "Tests failing",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{
        "expr": "count(synthetics_test{kind=\"PlaywrightTest\", namespace=\"$namespace\", name=~\"$test\"} == 0) or vector(0)",
        "refId": "A"
      }],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "red", "value": 1}
          ]},
          "color": {"mode": "thresholds"}
        }
      }
    },
    {
      "id": 3,
      "title": "Cases passing / failing (per run)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {"expr": "sum by (name) (synthetics_test_playwright_cases_passed{namespace=\"$namespace\", name=~\"$test\"})", "refId": "A", "legendFormat": "{{name}} passed"},
        {"expr": "sum by (name) (synthetics_test_playwright_cases_failed{namespace=\"$namespace\", name=~\"$test\"})", "refId": "B", "legendFormat": "{{name}} failed"}
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {"lineInterpolation": "stepAfter", "fillOpacity": 20}
        },
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": ".* failed$"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]},
          {"matcher": {"id": "byRegexp", "options": ".* passed$"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]}
        ]
      }
    },
    {
      "id": 4,
      "title": "Per-case pass/fail (latest run)",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 8},
      "targets": [{
        "expr": "synthetics_test_playwright_case_passed{namespace=\"$namespace\", name=~\"$test\"}",
        "refId": "A",
        "instant": true,
        "format": "table"
      }],
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "left"},
          "mappings": [
            {"type": "value", "options": {"0": {"text": "FAIL", "color": "red"}, "1": {"text": "PASS", "color": "green"}}}
          ]
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "Time"}, "properties": [{"id": "custom.hidden", "value": true}]},
          {"matcher": {"id": "byName", "options": "__name__"}, "properties": [{"id": "custom.hidden", "value": true}]},
          {"matcher": {"id": "byName", "options": "kind"}, "properties": [{"id": "custom.hidden", "value": true}]}
        ]
      }
    },
    {
      "id": 5,
      "title": "Case duration (ms)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 18},
      "targets": [{
        "expr": "synthetics_test_playwright_case_duration_ms{namespace=\"$namespace\", name=~\"$test\"}",
        "refId": "A",
        "legendFormat": "{{name}} — {{test}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {"fillOpacity": 10}
        }
      }
    },
    {
      "id": 6,
      "title": "Test run duration (ms)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 26},
      "targets": [{
        "expr": "synthetics_test_duration_ms{kind=\"PlaywrightTest\", namespace=\"$namespace\", name=~\"$test\"}",
        "refId": "A",
        "legendFormat": "{{name}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {"fillOpacity": 10}
        }
      }
    },
    {
      "id": 7,
      "title": "Last run (seconds ago)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 26},
      "targets": [{
        "expr": "time() - synthetics_test_last_run_timestamp{kind=\"PlaywrightTest\", namespace=\"$namespace\", name=~\"$test\"}",
        "refId": "A",
        "legendFormat": "{{name}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 300},
            {"color": "red", "value": 900}
          ]}
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      }
    }
  ]
}
