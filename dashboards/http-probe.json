    {
      "id": 23,
      "type": "table",
      "title": "Assertions",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 24,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "sortBy": [{"displayName": "Assertion"}],
        "footer": {"show": false}
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Result"},
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {"text": "FAIL", "color": "red", "index": 0},
                      "1": {"text": "PASS", "color": "green", "index": 1}
                    }
                  }
                ]
              },
              {"id": "custom.displayMode", "value": "color-background"},
              {"id": "custom.width", "value": 100}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Time"},
            "properties": [{"id": "custom.hidden", "value": true}]
          }
        ]
      },
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {"names": ["assertion", "expr", "Value"]}
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "assertion": "Assertion",
              "expr": "Expression",
              "Value": "Result"
            },
            "indexByName": {
              "assertion": 0,
              "expr": 1,
              "Value": 2
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "synthetics_probe_assertion_result{namespace=\"$namespace\", url=\"$url\"}",
          "legendFormat": "{{assertion}}",
          "instant": true,
          "refId": "A",
          "interval": "30s",
          "format": "table"
        }
      ]
