{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "title": "Overview",
      "url": "/d/synthetics-overview",
      "type": "link",
      "icon": "arrow-left",
      "targetBlank": false
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": [
    "synthetics",
    "dns"
  ],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Namespace",
        "multi": false,
        "name": "namespace",
        "options": [],
        "query": {
          "query": "label_values(synthetics_probe{kind=\"DNSProbe\"}, namespace)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        }
      },
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Probe",
        "multi": false,
        "name": "probe",
        "options": [],
        "query": {
          "query": "label_values(synthetics_probe{kind=\"DNSProbe\", namespace=\"$namespace\"}, name)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        }
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "Synthetics / DNS Probe",
  "uid": "synthetics-dns-probe",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Status",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN"
                },
                "1": {
                  "text": "UP"
                }
              }
            }
          ]
        }
      },
      "targets": [
        {
          "expr": "synthetics_probe{kind=\"DNSProbe\", namespace=\"$namespace\", name=\"$probe\"}",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Response Time",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0
        }
      },
      "targets": [
        {
          "expr": "synthetics_probe_dns_response_ms{namespace=\"$namespace\", name=\"$probe\"}",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Last Run",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeFromNow"
        }
      },
      "targets": [
        {
          "expr": "synthetics_probe_last_run_timestamp{kind=\"DNSProbe\", namespace=\"$namespace\", name=\"$probe\"} * 1000",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Answer Count",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "synthetics_probe_dns_response_answer_count{namespace=\"$namespace\", name=\"$probe\"}",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "First Answer Value",
      "description": "The value of the first DNS answer record. The label 'value' carries the string; the gauge value is always 1.",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "name",
        "colorMode": "none",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "No answer"
        }
      },
      "targets": [
        {
          "expr": "synthetics_probe_dns_response_first_answer_value{namespace=\"$namespace\", name=\"$probe\"}",
          "legendFormat": "{{value}}",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "state-timeline",
      "title": "Success",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "mergeValues": true,
        "showValue": "auto",
        "fillOpacity": 80,
        "rowHeight": 0.85,
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "range",
              "options": {
                "from": -0.5,
                "to": 0.5,
                "result": {
                  "color": "red",
                  "text": "DOWN",
                  "index": 0
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 0.5,
                "to": 1.5,
                "result": {
                  "color": "green",
                  "text": "UP",
                  "index": 1
                }
              }
            }
          ],
          "custom": {}
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "synthetics_probe{kind=\"DNSProbe\", namespace=\"$namespace\", name=\"$probe\"}",
          "legendFormat": "{{name}}",
          "refId": "A",
          "range": true
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Response Time",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisColorMode": "text",
            "scaleDistribution": {
              "type": "linear"
            },
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "synthetics_probe_dns_response_ms{namespace=\"$namespace\", name=\"$probe\"}",
          "legendFormat": "response time",
          "refId": "A",
          "range": true
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "DNS Section Counts",
      "description": "Number of records in each section of the DNS response.",
      "gridPos": {
        "h": 7,
        "w": 24,
        "x": 0,
        "y": 11
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 5,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisColorMode": "text",
            "scaleDistribution": {
              "type": "linear"
            },
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "synthetics_probe_dns_response_answer_count{namespace=\"$namespace\", name=\"$probe\"}",
          "legendFormat": "answer",
          "refId": "A",
          "range": true
        },
        {
          "expr": "synthetics_probe_dns_response_authority_count{namespace=\"$namespace\", name=\"$probe\"}",
          "legendFormat": "authority",
          "refId": "B",
          "range": true
        },
        {
          "expr": "synthetics_probe_dns_response_additional_count{namespace=\"$namespace\", name=\"$probe\"}",
          "legendFormat": "additional",
          "refId": "C",
          "range": true
        }
      ]
    },
    {
      "id": 20,
      "type": "alertlist",
      "title": "Alerts",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "datasource": {
        "type": "grafana",
        "uid": "-- Grafana --"
      },
      "options": {
        "viewMode": "list",
        "groupMode": "default",
        "groupBy": [],
        "alertName": "",
        "alertInstanceLabelFilter": "{probe_type=\"dns\", name=\"$probe\"}",
        "dashboardAlerts": false,
        "maxItems": 20,
        "sortOrder": 1,
        "stateFilter": {
          "error": true,
          "firing": true,
          "noData": true,
          "normal": true,
          "pending": true
        }
      }
    }
  ]
}
